{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hoban-jha-chunk-metadata",
  "title": "Hoban JHA Chunk Metadata Schema",
  "description": "전사 하위공종 위험요인 행 단위 청크의 메타데이터 스키마 (data-engineer Phase 2). jha-data-prep SKILL 단계 3 스키마 + dup_group / grade_inconsistent 확장.",
  "type": "object",
  "properties": {
    "chunk_id": {
      "type": "string",
      "pattern": "^R\\d{5}$",
      "description": "행 단위 청크 ID. R{source_row:05d}"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "청크 text의 SHA-256. 재인덱싱 차분 검출용"
    },
    "source_row": {
      "type": "integer",
      "minimum": 2,
      "description": "원본 Excel 행 번호 (헤더 1행, 데이터 2부터). lineage 추적 키"
    },
    "major_type_id": {"type": "string", "pattern": "^MJ\\d{3}$", "description": "대공종 안정 ID"},
    "major_type": {"type": "string", "description": "대공종 정규명"},
    "sub_type_id": {"type": "string", "pattern": "^SB\\d{3}$", "description": "중공종 안정 ID (대공종 종속 고유)"},
    "sub_type": {"type": "string", "description": "중공종 정규명"},
    "detail_item_id": {"type": "string", "pattern": "^DT\\d{4}$", "description": "세부항목 안정 ID ((대,중,세) 복합키 고유)"},
    "detail_item": {"type": "string", "description": "세부항목 정규명"},
    "accident_type": {
      "type": "string",
      "enum": ["추락","낙하","전도","협착","충돌","감전","화재","폭발","질식","근골격계","질환","비래","붕괴","도괴","베임","찔림","절단","말림","골절","직업성 질환","기타"],
      "description": "재해형태 (21종)"
    },
    "severity": {"type": "integer", "minimum": 1, "maximum": 5, "description": "강도(1~5)"},
    "frequency": {"type": "integer", "minimum": 1, "maximum": 5, "description": "빈도(1~5)"},
    "risk_product": {"type": "integer", "minimum": 1, "maximum": 25, "description": "강도×빈도 곱"},
    "risk_grade": {"type": "string", "enum": ["상","중","하"], "description": "원본 표기 위험등급 (원본 보존)"},
    "expected_grade": {
      "type": "string",
      "enum": ["상","중","하"],
      "description": "safety_scope 확정 임계곱 규칙(하<=9 / 중10~15 / 상>=16)으로 산출한 기대 등급"
    },
    "grade_inconsistent": {
      "type": "boolean",
      "description": "risk_grade != expected_grade 인 경우 true. 보정 금지 플래그. 본 데이터 35행(전부 s4×f4=곱16, 표기 '중')에 부여. safety-domain-expert 판단 대상"
    },
    "critical_register": {"type": "string", "enum": ["O","X"], "description": "중점등록 여부. 본 데이터에서 등급'상'과 1:1 일치"},
    "hazard_text": {"type": "string", "description": "정규화된 위험요인 텍스트 (불릿 제거·공백정리·복수항목 '·' 결합)"},
    "hazard_items": {"type": "array", "items": {"type": "string"}, "description": "셀 내 복수 위험요인 항목 분리 리스트"},
    "controls": {"type": "string", "description": "정규화된 개선대책 텍스트"},
    "controls_items": {"type": "array", "items": {"type": "string"}, "description": "셀 내 복수 개선대책 항목 분리 리스트"},
    "legal_refs": {"type": "array", "items": {"type": "string"}, "description": "법령 인용(산안법/안전보건규칙 조문). safety-domain-expert 매핑 연동 시 채움 (Phase 후속)"},
    "dup_group": {
      "type": "string",
      "description": "(중공종,세부항목,위험요인) 트리플 중복 그룹 ID (DG###). 미중복 시 빈 문자열. 본 데이터 7그룹·14행. 자동 제거하지 않고 유지"
    },
    "dup_content_of": {
      "type": "string",
      "description": "content_hash 동일(완전중복) 청크 중 후행에 부여. 최초 chunk_id를 기록. 본 데이터 2행"
    },
    "last_modified": {"type": "string", "format": "date-time", "description": "원본 파일 기준일 (2026-05-18)"}
  },
  "required": [
    "chunk_id", "content_hash", "source_row",
    "major_type_id", "major_type", "sub_type_id", "sub_type", "detail_item_id", "detail_item",
    "accident_type", "severity", "frequency", "risk_product",
    "risk_grade", "expected_grade", "grade_inconsistent",
    "critical_register", "hazard_text", "controls"
  ],
  "additionalProperties": false
}
