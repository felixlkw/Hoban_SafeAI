# Hoban JHA Backend — 환경변수 예시. 이 파일을 `.env` 로 복사해 실제 키를 채운다.
# `.env` 는 .gitignore 로 커밋 금지(이 .env.example 만 커밋).
# config._load_dotenv() 가 backend/.env 를 무의존 로드(이미 설정된 env 가 우선).

# ── LLM 공급자 ────────────────────────────────────────────────────────────
LLM_PROVIDER=openai                 # openai(기본) | anthropic | mock
OPENAI_API_KEY=                     # 부재 시 자동 Mock 폴백
# ANTHROPIC_API_KEY=                # LLM_PROVIDER=anthropic 일 때만

# ── 동적 위험 외부 공공 API (기상청·V-World) ────────────────────────────────
JHA_WEATHER_PROVIDER=mock           # mock(기본) | kma
JHA_GEO_PROVIDER=mock               # mock(기본) | vworld
DATA_GO_KR_SERVICE_KEY=             # data.go.kr 공통 serviceKey(단기예보·기상특보·에어코리아). Decoding 키
VWORLD_API_KEY=                     # V-World 인증키(도메인 등록 필수)
# JHA_EXTERNAL_API_TIMEOUT=4
# JHA_WEATHER_CACHE_TTL=600

# ── 기타 ──────────────────────────────────────────────────────────────────
# JHA_FORCE_MOCK=true               # 공급자 무관 Mock 강제(테스트)
# JHA_AUTH_ENABLED=false            # PoC 인증 우회
# JHA_LLM_TIMEOUT=30
