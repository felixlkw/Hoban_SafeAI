{
  "name": "hoban-jha-frontend",
  "version": "0.2.0",
  "private": true,
  "description": "호반 JHA Agent — 작업위험성평가 PoC 프론트엔드 (Next.js 14 App Router)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:mock": "cross-env NEXT_PUBLIC_USE_MOCK=true next build",
    "start:mock": "cross-env NEXT_PUBLIC_USE_MOCK=true next start -p 3100",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.45.3",
    "@testing-library/jest-dom": "6.4.6",
    "@testing-library/react": "16.0.0",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "20.14.10",
    "cross-env": "7.0.3",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.1",
    "autoprefixer": "10.4.19",
    "jsdom": "24.1.0",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.3",
    "vitest": "2.0.3"
  }
}
